# Anthropic 兼容注册路径（可选；只能填写明确允许应用后端使用的 Key/Base URL）
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
LLM_MODEL_ID=mimo-v2.5-pro

# 默认 Agent LLM：DeepSeek
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL_ID=deepseek-v4-pro
DEFAULT_LLM_PROVIDER=deepseek

# 讯飞语音转写 (可选)
XFYUN_APPID=your-xfyun-appid
XFYUN_SECRET_KEY=your-xfyun-secret

# MiMo 公共 OpenAI 兼容接口（余额扣费 Key；可用于 Agent LLM 和 ASR）
MIMO_API_KEY=your-mimo-api-key
MIMO_OPENAI_BASE_URL=https://api.xiaomimimo.com/v1
MIMO_CHAT_MODEL_ID=mimo-v2.5-pro
MIMO_ASR_BASE_URL=https://api.xiaomimimo.com/v1
MIMO_ASR_MODEL=mimo-v2.5-asr
MIMO_ASR_LANGUAGE=zh
TRANSCRIPT_PROVIDER=mimo
ASR_MAX_VIDEO_SECONDS=600
ASR_MAX_VIDEOS=5

# 产品数据库与认证（生产环境必须更换）
POSTGRES_DB=viral_video
POSTGRES_USER=viral_video
POSTGRES_PASSWORD=change-this-password
DATABASE_URL=postgresql+asyncpg://viral_video:change-this-password@localhost:5432/viral_video
JWT_SECRET=generate-a-long-random-secret
JWT_EXPIRE_MINUTES=10080
APP_ENV=development

# 后台任务
REDIS_URL=redis://localhost:6379/0
WORKER_MAX_JOBS=2
JOB_TIMEOUT_SECONDS=600
JOB_MAX_RETRIES=2
USER_MONTHLY_JOB_LIMIT=30

# Agent 配置
ANALYSIS_CONFIDENCE_THRESHOLD=0.8
ANALYST_MAX_ITERATIONS=5
WRITER_MAX_REVISIONS=3
GRAPH_VERSION=v2
V2_ANALYST_MAX_ITERATIONS=2
V2_WRITER_MAX_REVISIONS=1
V2_MIN_EVIDENCE_ITEMS=1
PROMPT_VERSION=v1

# 本地直跑默认地址；Docker Compose 会覆盖为 http://mcp-server:8001/sse
MCP_SERVER_URL=http://localhost:8001/sse

# 默认禁止把随机演示数据送入分析报告；仅在明确做UI演示时临时开启
ENABLE_MOCK_TOOLS=false

# 微调模型接入 (可选，只切换 Researcher Agent)
USE_FINETUNED_MODEL=false
FINETUNED_MODEL_URL=http://host.docker.internal:8002/v1
