# MiMo (Anthropic 兼容接口)
ANTHROPIC_API_KEY=your-mimo-api-key
ANTHROPIC_BASE_URL=https://token-plan-cn.xiaomimimo.com/anthropic
LLM_MODEL_ID=mimo-v2.5-pro

# DeepSeek (可选，备用模型)
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL_ID=deepseek-chat

# 讯飞语音转写 (可选)
XFYUN_APPID=your-xfyun-appid
XFYUN_SECRET_KEY=your-xfyun-secret

# Agent 配置
ANALYSIS_CONFIDENCE_THRESHOLD=0.8
ANALYST_MAX_ITERATIONS=5
WRITER_MAX_REVISIONS=3
GRAPH_VERSION=v2
V2_ANALYST_MAX_ITERATIONS=2
V2_WRITER_MAX_REVISIONS=1
V2_MIN_EVIDENCE_ITEMS=1
PROMPT_VERSION=v1

# 本地直跑默认地址；Docker Compose 会覆盖为 http://mcp-server:8001/sse
MCP_SERVER_URL=http://localhost:8001/sse

# 默认禁止把随机演示数据送入分析报告；仅在明确做UI演示时临时开启
ENABLE_MOCK_TOOLS=false

# 微调模型接入 (可选，只切换 Researcher Agent)
USE_FINETUNED_MODEL=false
FINETUNED_MODEL_URL=http://host.docker.internal:8002/v1
